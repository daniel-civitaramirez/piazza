# Admin (optional — leave empty to auto-approve all groups)
ADMIN_JID=

# Evolution API
# Note: EVO_API_URL, OLLAMA_URL, REDIS_URL are overridden by docker-compose.prod.yml
# to use container hostnames. The defaults below are for local development.
EVO_API_KEY=your-random-api-key-here
EVO_API_URL=http://localhost:8080
EVO_INSTANCE_NAME=piazza-main
EVO_DB_PASSWORD=generate-a-random-password
BOT_JID=5511888888888@s.whatsapp.net
BOT_LID=75192697139363@lid  # auto-discovered on first group join, then set here for persistence

# Domain (used by Caddy for auto-TLS)
DOMAIN=piazza.yourdomain.com

# Database (Supabase — use port 6543 for Supavisor transaction mode)
SUPABASE_DB_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:6543/postgres?ssl=require

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_URL=http://localhost:11434

# Security
ENCRYPTION_KEY=base64-encoded-32-byte-key
WEBHOOK_SECRET=your-webhook-hmac-secret
INJECTION_PATTERNS_PATH=config/injection_patterns.json

# External APIs (optional in MVP)
OPENEXCHANGERATES_KEY=your-key

# Monitoring (optional)
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# LLM model config (optional — defaults shown)
# OLLAMA_MODEL=qwen3.5:4b
# OLLAMA_TIMEOUT=10.0
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_TIMEOUT=15.0
# CLAUDE_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.0

# Circuit breaker (optional — defaults shown)
# CIRCUIT_BREAKER_FAILURES=3
# CIRCUIT_BREAKER_WINDOW=120
# CIRCUIT_BREAKER_COOLDOWN=600

# Input validation (optional — defaults shown)
# MAX_MESSAGE_LENGTH=500
# DEFAULT_CURRENCY=EUR

# WhatsApp client tuning (optional — defaults shown)
# WA_SEND_MAX_RETRIES=3
# WA_SEND_BACKOFF_BASE=0.5
# WA_CLIENT_TIMEOUT=10.0
# HEALTH_CHECK_TIMEOUT=5.0

# Agent (optional — defaults shown)
# CONVERSATION_CONTEXT_LIMIT=10

# Worker tuning (optional — defaults shown)
# WORKER_MAX_JOBS=10
# WORKER_JOB_TIMEOUT=30
# HUMAN_DELAY_MIN=1.0
# HUMAN_DELAY_MAX=3.0
# REMINDER_CRON_SECONDS=0,30
